# Environment variables for the research pipeline
# All APIs below have free tiers — no credit card required

# Required: Groq API key (free at console.groq.com)
GROQ_API_KEY=gsk_your_key_here

# Required: Serper API key (free 2,500 queries at serper.dev)
SERPER_API_KEY=your_key_here

# Optional: Jina API key (free 10M tokens at jina.ai — works without key too, just slower)
JINA_API_KEY=

# Optional: Composio API key (free 20K tool calls/month at app.composio.dev)
COMPOSIO_API_KEY=

# Optional: Tavily API key (free 1,000 credits/month at tavily.com — fallback search)
TAVILY_API_KEY=

# Optional: Google Gemini API key (free tier at aistudio.google.com — fallback LLM)
GOOGLE_API_KEY=
